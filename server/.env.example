# Backend Environment Variables
# Copy this file to .env and fill in your values

# ========== DATABASE ==========
# MongoDB Atlas Connection String
# Get this from: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/database-name
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/procrastination-killer

# ========== JWT ==========
# Generated secret key for JWT token signing
# Generate with: openssl rand -base64 32
# IMPORTANT: Change this in production!
JWT_SECRET=replace_with_secure_secret

# JWT token expiration time
JWT_EXPIRES_IN=7d

# ========== SERVER ==========
# Port to run the Express server
PORT=5000

# Node environment
NODE_ENV=development

# ========== CORS ==========
# Frontend URL for CORS configuration
# Development: http://localhost:5173
# Production: https://your-frontend.vercel.app
CLIENT_URL=http://localhost:5173
